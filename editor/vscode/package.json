{
  "name": "benoit-lang",
  "displayName": "Benoît Language",
  "description": "Syntax highlighting for the Benoît programming language (.ben files)",
  "version": "0.4.0",
  "publisher": "SanTiepi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SanTiepi/benoit"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": ["Programming Languages"],
  "contributes": {
    "languages": [{
      "id": "benoit",
      "aliases": ["Benoît", "benoit"],
      "extensions": [".ben"],
      "configuration": "./language-configuration.json"
    }],
    "grammars": [{
      "language": "benoit",
      "scopeName": "source.benoit",
      "path": "./syntaxes/benoit.tmLanguage.json"
    }]
  }
}
