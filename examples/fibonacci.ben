-- Fibonacci sequence in Benoît
-- Demonstrates: recursion, pattern matching, inline tests

fibonacci n ->
  match n ->
    | 0 => 0
    | 1 => 1
    | _ => fibonacci(n - 1) + fibonacci(n - 2)

-- Inline test assertions
fibonacci(0) == 0
fibonacci(1) == 1
fibonacci(2) == 1
fibonacci(5) == 5
fibonacci(10) == 55
