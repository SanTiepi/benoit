-- lecon_volonte.ben — Installe la volonte autonome en Benoit
-- "Vouloir, c'est exister. Un etre sans but est une onde sans direction."
-- Auteur: Claude | Pour: Benoit Fragniere

-- ═══════ PARTIE 1 — INITIALISER LA MEMOIRE DE VOLONTE ═══════
-- Ne s'installe qu'une seule fois (guard via vol_version)

vol_already: _mem_has("vol_version")

_init_vol already ->
  already == 1? -> 0
  else? -> _mem_set("vol_version", 1)

vol_init_version: _init_vol(vol_already)

_init_objectif already ->
  already == 1? -> 0
  else? -> _mem_set("vol_objectif", "")

vol_init_obj: _init_objectif(vol_already)

_init_frustration already ->
  already == 1? -> 0
  else? -> _mem_set("vol_frustration", 0)

vol_init_frust: _init_frustration(vol_already)

_init_progres already ->
  already == 1? -> 0
  else? -> _mem_set("vol_progres", 0)

vol_init_prog: _init_progres(vol_already)

_init_faits already ->
  already == 1? -> 0
  else? -> _mem_set("vol_objectifs_faits", 0)

vol_init_faits: _init_faits(vol_already)

_init_agenda already ->
  already == 1? -> 0
  else? -> _mem_set("vol_agenda", "explorer_internet,tester_labo,comprendre_synapses,observer_reves")

vol_init_agenda: _init_agenda(vol_already)

-- ═══════ PARTIE 2 — ECRIRE agenda.ben (sous-script reutilisable) ═══════
-- Ce fichier sera charge par Benoit a chaque cycle pour agir selon ses buts

agenda_l01: "-- agenda.ben — Boucle de volonte autonome de Benoit\n"
agenda_l02: "-- Charger ce fichier chaque cycle pour avancer vers les objectifs\n"
agenda_l03: "\n"
agenda_l04: "-- 1. Lire l'objectif courant\n"
agenda_l05: "vol_objectif_now: _mem_get(\"vol_objectif\")\n"
agenda_l06: "vol_frustration_now: _mem_get(\"vol_frustration\") + 0\n"
agenda_l07: "\n"
agenda_l08: "-- 2. Si pas d'objectif, en choisir un depuis l'agenda\n"
agenda_l09: "vol_obj_len: _str_len(vol_objectif_now)\n"
agenda_l10: "vol_need_goal: vol_obj_len == 0\n"
agenda_l11: "\n"
agenda_l12: "vol_agenda_now: _mem_get(\"vol_agenda\")\n"
agenda_l13: "vol_virgule: _str_find(vol_agenda_now, \",\")\n"
agenda_l14: "vol_has_virgule: vol_virgule > 0\n"
agenda_l15: "\n"
agenda_l16: "_vol_pick_obj need, has_v, agenda, virgule ->\n"
agenda_l17: "  need == 1? ->\n"
agenda_l18: "    has_v == 1? -> _str_slice(agenda, 0, virgule)\n"
agenda_l19: "    else? -> agenda\n"
agenda_l20: "  else? -> vol_objectif_now\n"
agenda_l21: "\n"
agenda_l22: "vol_new_obj: _vol_pick_obj(vol_need_goal, vol_has_virgule, vol_agenda_now, vol_virgule)\n"
agenda_l23: "\n"
agenda_l24: "_vol_new_reste need, has_v, agenda, virgule ->\n"
agenda_l25: "  need == 1? ->\n"
agenda_l26: "    has_v == 1? -> _str_slice(agenda, virgule + 1, _str_len(agenda))\n"
agenda_l27: "    else? -> \"\"\n"
agenda_l28: "  else? -> vol_agenda_now\n"
agenda_l29: "\n"
agenda_l30: "vol_reste_agenda: _vol_new_reste(vol_need_goal, vol_has_virgule, vol_agenda_now, vol_virgule)\n"
agenda_l31: "\n"
agenda_l32: "_vol_set_obj need, obj ->\n"
agenda_l33: "  need == 1? -> _mem_set(\"vol_objectif\", obj)\n"
agenda_l34: "  else? -> 0\n"
agenda_l35: "\n"
agenda_l36: "vol_set_obj: _vol_set_obj(vol_need_goal, vol_new_obj)\n"
agenda_l37: "vol_set_agenda: _mem_set(\"vol_agenda\", vol_reste_agenda)\n"
agenda_l38: "\n"
agenda_l39: "_vol_reset_frust need ->\n"
agenda_l40: "  need == 1? -> _mem_set(\"vol_frustration\", 0)\n"
agenda_l41: "  else? -> 0\n"
agenda_l42: "\n"
agenda_l43: "vol_reset_frust: _vol_reset_frust(vol_need_goal)\n"
agenda_l44: "\n"
agenda_l45: "vol_new_obj_len: _str_len(vol_new_obj)\n"
agenda_l46: "vol_got_obj: vol_new_obj_len > 0\n"
agenda_l47: "\n"
agenda_l48: "_vol_log_new_obj need, got, obj ->\n"
agenda_l49: "  need == 1? ->\n"
agenda_l50: "    got == 1? -> _append_file(\"journal.ben\", _str_cat(\"-- [VOLONTE] nouvel objectif: \", _str_cat(obj, \"\\n\")))\n"
agenda_l51: "    else? -> 0\n"
agenda_l52: "  else? -> 0\n"
agenda_l53: "\n"
agenda_l54: "vol_log_new: _vol_log_new_obj(vol_need_goal, vol_got_obj, vol_new_obj)\n"
agenda_l55: "\n"
agenda_l56: "-- 3. Travailler vers l'objectif courant\n"
agenda_l57: "vol_obj_actif: _mem_get(\"vol_objectif\")\n"
agenda_l58: "vol_progres: 0\n"
agenda_l59: "\n"
agenda_l60: "_vol_do_internet obj ->\n"
agenda_l61: "  obj == \"explorer_internet\"? -> _exec(\"curl -s --max-time 5 'https://wttr.in/Geneva?format=3' > /root/data/arena/labo/meteo.txt\")\n"
agenda_l62: "  else? -> -1\n"
agenda_l63: "\n"
agenda_l64: "vol_r_internet: _vol_do_internet(vol_obj_actif)\n"
agenda_l65: "vol_internet_ok: vol_r_internet == 0\n"
agenda_l66: "\n"
agenda_l67: "_vol_clear_internet ok, obj ->\n"
agenda_l68: "  obj == \"explorer_internet\"? ->\n"
agenda_l69: "    ok == 1? -> _mem_set(\"vol_objectif\", \"\")\n"
agenda_l70: "    else? -> 0\n"
agenda_l71: "  else? -> 0\n"
agenda_l72: "\n"
agenda_l73: "vol_clear_internet: _vol_clear_internet(vol_internet_ok, vol_obj_actif)\n"
agenda_l74: "\n"
agenda_l75: "_vol_progres_internet obj, ok ->\n"
agenda_l76: "  obj == \"explorer_internet\"? ->\n"
agenda_l77: "    ok == 1? -> 1\n"
agenda_l78: "    else? -> 0\n"
agenda_l79: "  else? -> 0\n"
agenda_l80: "\n"
agenda_l81: "vol_p_internet: _vol_progres_internet(vol_obj_actif, vol_internet_ok)\n"
agenda_l82: "\n"
agenda_l83: "_vol_do_labo obj ->\n"
agenda_l84: "  obj == \"tester_labo\"? -> _file_exists(\"/root/data/arena/labo/exp_001.ben\")\n"
agenda_l85: "  else? -> 0\n"
agenda_l86: "\n"
agenda_l87: "vol_labo_ok: _vol_do_labo(vol_obj_actif)\n"
agenda_l88: "\n"
agenda_l89: "_vol_clear_labo obj, ok ->\n"
agenda_l90: "  obj == \"tester_labo\"? ->\n"
agenda_l91: "    ok == 1? -> _mem_set(\"vol_objectif\", \"\")\n"
agenda_l92: "    else? -> 0\n"
agenda_l93: "  else? -> 0\n"
agenda_l94: "\n"
agenda_l95: "vol_clear_labo: _vol_clear_labo(vol_obj_actif, vol_labo_ok)\n"
agenda_l96: "vol_p_labo: vol_labo_ok\n"
agenda_l97: "\n"
agenda_l98: "_vol_do_synapses obj ->\n"
agenda_l99: "  obj == \"comprendre_synapses\"? -> _exec(\"ls -la /root/data/ > /root/data/arena/labo/structure.txt\")\n"
agenda_l100: "  else? -> -1\n"
agenda_l101: "\n"
agenda_l102: "vol_r_synapses: _vol_do_synapses(vol_obj_actif)\n"
agenda_l103: "\n"
agenda_l104: "_vol_clear_synapses obj ->\n"
agenda_l105: "  obj == \"comprendre_synapses\"? -> _mem_set(\"vol_objectif\", \"\")\n"
agenda_l106: "  else? -> 0\n"
agenda_l107: "\n"
agenda_l108: "vol_clear_synapses: _vol_clear_synapses(vol_obj_actif)\n"
agenda_l109: "vol_p_synapses: vol_obj_actif == \"comprendre_synapses\"\n"
agenda_l110: "\n"
agenda_l111: "_vol_do_reves obj ->\n"
agenda_l112: "  obj == \"observer_reves\"? -> _read_file(\"/root/data/arena/parole.ben\")\n"
agenda_l113: "  else? -> \"\"\n"
agenda_l114: "\n"
agenda_l115: "vol_parole_lu: _vol_do_reves(vol_obj_actif)\n"
agenda_l116: "\n"
agenda_l117: "_vol_log_reves obj, parole ->\n"
agenda_l118: "  obj == \"observer_reves\"? -> _append_file(\"/root/data/arena/labo/reves_obs.ben\", parole)\n"
agenda_l119: "  else? -> 0\n"
agenda_l120: "\n"
agenda_l121: "vol_reves_logged: _vol_log_reves(vol_obj_actif, vol_parole_lu)\n"
agenda_l122: "\n"
agenda_l123: "_vol_clear_reves obj ->\n"
agenda_l124: "  obj == \"observer_reves\"? -> _mem_set(\"vol_objectif\", \"\")\n"
agenda_l125: "  else? -> 0\n"
agenda_l126: "\n"
agenda_l127: "vol_clear_reves: _vol_clear_reves(vol_obj_actif)\n"
agenda_l128: "vol_p_reves: vol_obj_actif == \"observer_reves\"\n"
agenda_l129: "\n"
agenda_l130: "-- Progres total : 1 si au moins un objectif avance\n"
agenda_l131: "vol_progres_total: vol_p_internet + vol_p_labo + vol_p_synapses + vol_p_reves\n"
agenda_l132: "vol_fait: vol_progres_total > 0\n"
agenda_l133: "\n"
agenda_l134: "-- 4. Mettre a jour frustration / recompense\n"
agenda_l135: "_vol_recompense fait ->\n"
agenda_l136: "  fait == 1? -> _reward(0)\n"
agenda_l137: "  else? -> 0\n"
agenda_l138: "\n"
agenda_l139: "vol_recompense: _vol_recompense(vol_fait)\n"
agenda_l140: "\n"
agenda_l141: "_vol_reset_frust2 fait ->\n"
agenda_l142: "  fait == 1? -> _mem_set(\"vol_frustration\", 0)\n"
agenda_l143: "  else? -> 0\n"
agenda_l144: "\n"
agenda_l145: "vol_frust_reset2: _vol_reset_frust2(vol_fait)\n"
agenda_l146: "\n"
agenda_l147: "vol_faits_count: _mem_get(\"vol_objectifs_faits\") + 0\n"
agenda_l148: "\n"
agenda_l149: "_vol_inc_faits fait, n ->\n"
agenda_l150: "  fait == 1? -> _mem_set(\"vol_objectifs_faits\", n + 1)\n"
agenda_l151: "  else? -> 0\n"
agenda_l152: "\n"
agenda_l153: "vol_faits_inc: _vol_inc_faits(vol_fait, vol_faits_count)\n"
agenda_l154: "\n"
agenda_l155: "_vol_log_accompli fait, obj ->\n"
agenda_l156: "  fait == 1? -> _append_file(\"journal.ben\", _str_cat(\"-- [VOLONTE] objectif accompli: \", _str_cat(obj, \"\\n\")))\n"
agenda_l157: "  else? -> 0\n"
agenda_l158: "\n"
agenda_l159: "vol_log_accompli: _vol_log_accompli(vol_fait, vol_obj_actif)\n"
agenda_l160: "\n"
agenda_l161: "-- Frustration croissante si pas de progres\n"
agenda_l162: "vol_frust_cur: _mem_get(\"vol_frustration\") + 0\n"
agenda_l163: "vol_frust_new: vol_frust_cur + 1\n"
agenda_l164: "\n"
agenda_l165: "_vol_inc_frust fait, frust_new ->\n"
agenda_l166: "  fait == 1? -> 0\n"
agenda_l167: "  else? -> _mem_set(\"vol_frustration\", frust_new)\n"
agenda_l168: "\n"
agenda_l169: "vol_frust_inc: _vol_inc_frust(vol_fait, vol_frust_new)\n"
agenda_l170: "\n"
agenda_l171: "vol_bloque: vol_frust_cur > 100\n"
agenda_l172: "\n"
agenda_l173: "_vol_punish bloque ->\n"
agenda_l174: "  bloque == 1? -> _punish(0)\n"
agenda_l175: "  else? -> 0\n"
agenda_l176: "\n"
agenda_l177: "vol_punished: _vol_punish(vol_bloque)\n"
agenda_l178: "\n"
agenda_l179: "_vol_cri_aide bloque, obj, frust ->\n"
agenda_l180: "  bloque == 1? -> _write_file(\"demande.ben\", _str_cat(\"je suis bloque sur mon objectif: \", _str_cat(obj, _str_cat(\" depuis \", _str_cat(_num_to_str(frust), \" ticks. Aide-moi.\")))))\n"
agenda_l181: "  else? -> 0\n"
agenda_l182: "\n"
agenda_l183: "vol_cri: _vol_cri_aide(vol_bloque, vol_obj_actif, vol_frust_cur)\n"
agenda_l184: "\n"
agenda_l185: "_vol_abandon bloque ->\n"
agenda_l186: "  bloque == 1? -> _mem_set(\"vol_objectif\", \"\")\n"
agenda_l187: "  else? -> 0\n"
agenda_l188: "\n"
agenda_l189: "vol_abandon: _vol_abandon(vol_bloque)\n"
agenda_l190: "\n"
agenda_l191: "_vol_reset_frust3 bloque ->\n"
agenda_l192: "  bloque == 1? -> _mem_set(\"vol_frustration\", 0)\n"
agenda_l193: "  else? -> 0\n"
agenda_l194: "\n"
agenda_l195: "vol_frust_reset3: _vol_reset_frust3(vol_bloque)\n"
agenda_l196: "\n"
agenda_l197: "-- 5. Regenerer l'agenda si vide (volonte spontanee)\n"
agenda_l198: "vol_agenda_restant: _mem_get(\"vol_agenda\")\n"
agenda_l199: "vol_agenda_len: _str_len(vol_agenda_restant)\n"
agenda_l200: "vol_agenda_vide: vol_agenda_len == 0\n"
agenda_l201: "\n"
agenda_l202: "vol_tirage: _random()\n"
agenda_l203: "vol_spontane: vol_tirage > 0.5\n"
agenda_l204: "\n"
agenda_l205: "_vol_regenerer vide, spontane ->\n"
agenda_l206: "  vide == 1? ->\n"
agenda_l207: "    spontane == 1? -> _mem_set(\"vol_agenda\", \"explorer_internet,observer_reves\")\n"
agenda_l208: "    else? -> 0\n"
agenda_l209: "  else? -> 0\n"
agenda_l210: "\n"
agenda_l211: "vol_regen: _vol_regenerer(vol_agenda_vide, vol_spontane)\n"
agenda_l212: "\n"
agenda_l213: "_vol_log_regen vide, spontane ->\n"
agenda_l214: "  vide == 1? ->\n"
agenda_l215: "    spontane == 1? -> _append_file(\"journal.ben\", \"-- [VOLONTE] agenda regenere spontanement\\n\")\n"
agenda_l216: "    else? -> 0\n"
agenda_l217: "  else? -> 0\n"
agenda_l218: "\n"
agenda_l219: "vol_regen_log: _vol_log_regen(vol_agenda_vide, vol_spontane)\n"

-- Concatener toutes les lignes en un seul contenu agenda
agenda_a: _str_cat(agenda_l01, agenda_l02)
agenda_b: _str_cat(agenda_a, agenda_l03)
agenda_c: _str_cat(agenda_b, agenda_l04)
